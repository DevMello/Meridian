  ASSISTANT = {
    reg: [
      { id:'cheap', q:'Which one is cheapest?', a:'The MP1584EN is cheapest at $0.41/unit on LCSC — but it\u2019s non-synchronous, so efficiency at 3 A is lower. For a balanced 24 V→5 V rail I\u2019d rank the LMR33630 ($1.62) first: synchronous, 36 V input margin, and full CAD models.' },
      { id:'eff', q:'Which is most efficient?', a:'The LT8609 (~93%) and LMR33630 (~92%) lead — both synchronous with integrated low-side FETs. The LM2596 is an older non-sync part at ~75%, so it runs noticeably hotter at 3 A.' },
      { id:'thermal', q:'Best for a tight thermal budget?', a:'Go synchronous: LMR33630 or LT8609. At 3 A / 24 V→5 V they dissipate roughly a third of what the LM2596 does, so you can often skip the heatsink. The LMR33630\u2019s HSOIC-8 pad sinks heat well into the board.' },
    ],
    esp: [
      { id:'cheap', q:'Which one is cheapest?', a:'The ESP32-C3-WROOM-02 is cheapest at $1.15 (LCSC) — but it exposes USB Serial only, not native USB OTG. If you need true USB device support, the ESP32-C6 ($1.87) is the lowest-cost part that fits your USB-C requirement.' },
      { id:'usb', q:'Which has real USB support?', a:'The ESP32-S3 and S3-MINI have native USB OTG (full device/host). The C6 and C3 have a USB Serial/JTAG controller — fine for programming and CDC, but not full OTG. For USB-C data beyond serial, pick the S3.' },
      { id:'power', q:'Which has lower power?', a:'The ESP32-C6 (single RISC-V, Wi-Fi 6 target wake time) has the best idle/sleep profile. The dual-core S3 draws more active current but finishes compute-heavy work faster — better for bursty ML workloads.' },
    ],
    opamp: [
      { id:'noise', q:'Which has the lowest noise?', a:'The LT1028 at 0.85 nV/√Hz is best-in-class — but it needs ±4 V minimum and draws 7.4 mA. For a single 5 V rail, the OPA2189 (5.2 nV/√Hz) or ADA4522 (5.8 nV/√Hz) give excellent noise with true single-supply operation.' },
      { id:'cheap', q:'Which one is cheapest?', a:'The OPA333 at $2.20 is the most affordable and runs directly on 1.8–5.5 V — the cleanest fit for a 5 V precision front-end if 55 nV/√Hz noise is acceptable.' },
      { id:'drift', q:'Which has the best DC precision?', a:'The OPA2189 leads on offset (±3 µV) and drift (0.02 µV/°C), both zero-drift. The OPA333 is close and cheaper. The LT1028 is a noise specialist, not a drift specialist (0.8 µV/°C).' },
    ],
  };

  // ---------- helpers ----------
  cur() { return this.DATASETS[this.state.ds]; }
  activeProviders() { return this.PROVIDERS.filter(p => this.state.providers[p.id]); }
  fmt(n) { return n >= 1000 ? (n/1000).toFixed(n>=100000?0:1).replace(/\.0$/,'') + 'k' : String(n); }
  partById(id) { return this.cur().parts.find(p => p.id === id); }

  navItem(active) {
    return `display:flex;align-items:center;gap:11px;padding:8px 10px;border-radius:9px;border:none;cursor:pointer;font-size:14px;text-align:left;width:100%;transition:background .15s;${active?'background:#0c0b09;color:#f4efe8':'background:none;color:#0c0b09'}`;
  }
  capChip(cap, dark) {
    const c = this.CAP_COLORS[cap] || '#8a8378';
    return `font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.04em;padding:2px 7px;border-radius:5px;background:${c}1f;color:${c};text-transform:uppercase`;
  }

  // ---------- flow ----------
  detectDataset(q) {
    const s = (q||'').toLowerCase();
    if (/esp32|bluetooth|usb-c|mcu|wifi|wi-fi/.test(s)) return 'esp';
    if (/amp|op-?amp|noise|amplifier/.test(s)) return 'opamp';
    return 'reg';
  }
  runQuery(dsKey, qText) {
    if (this.timers) this.timers.forEach(clearTimeout);
    this.timers = [];
    const ds = this.DATASETS[dsKey];
    const q = qText || ds.query;
    this.setState({ view:'parsing', ds:dsKey, query:q, draftQuery:q, parseStep:0, compare:[], selected:null });
    const nFilters = ds.filters.length;
    const nProv = this.activeProviders().length;
    const total = nFilters + nProv + 2;
    for (let i=1;i<=total;i++){
      this.timers.push(setTimeout(()=>{
        if (i>=total) { this.pushHistory(q, dsKey); this.setState({ view:'results', parseStep:i }); }
        else this.setState({ parseStep:i });
      }, 340*i + 200));
    }
  }
  pushHistory(q, ds) {
    const now = new Date();
    const t = now.getHours().toString().padStart(2,'0')+':'+now.getMinutes().toString().padStart(2,'0');
    const provs = this.activeProviders().slice(0,3).map(p=>p.name).join(' · ');
    this.setState(s => ({ history:[{time:t,q:q.replace(/\.$/,''),providers:provs,ds},...s.history].slice(0,12) }));
  }
  submitSearch = () => {
    const q = (this.state.draftQuery||'').trim();
    if (!q) return;
    this.runQuery(this.detectDataset(q), q);
  };
  onQueryChange = (e) => this.setState({ draftQuery: e.target.value });
  onQueryKey = (e) => { if (e.key === 'Enter') this.submitSearch(); };

  goHome = () => this.setState({ view:'home' });
  goSaved = () => this.setState({ view:'saved' });
  goHistory = () => this.setState({ view:'history' });
  goProviders = () => this.setState({ view:'providers' });
  goSearch = () => this.setState({ view: this.state.query ? 'results' : 'home' });
  goCompare = () => { if (this.state.compare.length) this.setState({ view:'compare' }); };

  toggleProvider(id) { this.setState(s => ({ providers:{...s.providers,[id]:!s.providers[id]} })); }
  toggleCapView = () => this.setState(s => ({ showCaps:!s.showCaps }));

  setLayout(l) { this.setState({ layout:l }); }

  removeFilter(i) { /* visual only in prototype */ }

  openDetail(id) { this.setState({ view:'detail', selected:id, detailTab:'overview', importOpen:false }); }
  backToResults = () => this.setState({ view:'results' });
  setTab(t) { this.setState({ detailTab:t }); }
  toggleImport = () => this.setState(s => ({ importOpen:!s.importOpen }));
  pickImport(target, mpn) { this.setState({ importOpen:false }); this.showToast('Importing '+mpn+' into '+target+' — resolving CAD source…'); }
  showToast(msg){ if(this.tTimer) clearTimeout(this.tTimer); this.setState({toast:msg}); this.tTimer=setTimeout(()=>this.setState({toast:''}),2600); }

  toggleCompareId(id) {
    this.setState(s => {
      const has = s.compare.includes(id);
      if (has) return { compare: s.compare.filter(x=>x!==id) };
      if (s.compare.length >= 3) return {};
      return { compare: [...s.compare, id] };
    });
  }
  openCompare = () => this.setState({ view:'compare' });
  clearCompare = () => this.setState({ compare:[] });

  toggleSave(id) { this.setState(s => ({ saved: s.saved.includes(id) ? s.saved.filter(x=>x!==id) : [...s.saved, id] })); }

  toggleAssistant = () => this.setState(s => ({ assistantOpen:!s.assistantOpen }));
  sendPreset(item) {
    this.setState(s => ({ chat:[...s.chat, {role:'user',text:item.q}], typing:true }));
    if (this.aTimer) clearTimeout(this.aTimer);
    this.aTimer = setTimeout(()=> this.setState(s => ({ chat:[...s.chat, {role:'ai',text:item.a}], typing:false })), 900);
  }

  componentWillUnmount(){ if(this.timers) this.timers.forEach(clearTimeout); if(this.aTimer) clearTimeout(this.aTimer); }

  // ---------- render ----------
  renderVals() {
    const s = this.state;
    const ds = this.cur();
    const view = s.view;
    const actives = this.activeProviders();
    const providerCount = actives.length;

    // nav
    const inSearch = ['home','parsing','results','detail','compare'].includes(view);
    const crumbMap = { home:['ComponentHub','Search'], parsing:['ComponentHub','Search'], results:['ComponentHub','Results'], detail:['ComponentHub','Results',(this.partById(s.selected)||{}).mpn||'Part'], compare:['ComponentHub','Compare'], saved:['ComponentHub','Saved'], history:['ComponentHub','History'], providers:['ComponentHub','Providers'] };
    const crumbArr = crumbMap[view] || ['ComponentHub'];
    const crumb = crumbArr.map((label,i)=>({ label: i>0 ? '/ '+label : label, style: i===crumbArr.length-1?'color:#0c0b09':'color:#8a8378' }));

    // providers enriched
    const providersList = this.PROVIDERS.map(p => {
      const checked = !!s.providers[p.id];
      return {
        ...p, checked, kind:p.kind,
        toggle: () => this.toggleProvider(p.id),
        caps: p.caps.map(c=>({label:c, style:this.capChip(c)})),
        cardStyle: `text-align:left;cursor:pointer;border-radius:14px;padding:16px;border:1px solid ${checked?'rgba(239,106,42,.4)':'rgba(12,11,9,.1)'};background:${checked?'rgba(239,106,42,.05)':'#f8f5f0'};transition:all .15s`,
        checkStyle: `width:22px;height:22px;flex:none;border-radius:7px;display:flex;align-items:center;justify-content:center;border:1.5px solid ${checked?'#ef6a2a':'rgba(12,11,9,.2)'};background:${checked?'#ef6a2a':'transparent'}`,
        mgrStyle: `border-radius:16px;padding:20px;border:1px solid ${checked?'rgba(239,106,42,.35)':'rgba(12,11,9,.08)'};background:#f8f5f0;opacity:${checked?1:.62};transition:all .15s`,
        switchStyle: `width:42px;height:24px;border-radius:999px;border:none;cursor:pointer;position:relative;background:${checked?'#ef6a2a':'rgba(12,11,9,.15)'};transition:background .15s;flex:none`,
        knobStyle: `position:absolute;top:3px;left:${checked?'21px':'3px'};width:18px;height:18px;border-radius:50%;background:#fff;transition:left .15s`,
      };
    });

    // suggestions & recents (home)
    const suggestions = [
      { label:'24V→5V regulator, 3A', ds:'reg', q:this.DATASETS.reg.query },
      { label:'ESP32 with BLE + USB-C', ds:'esp', q:this.DATASETS.esp.query },
      { label:'Low-noise amp ~5V', ds:'opamp', q:this.DATASETS.opamp.query },
    ].map(x=>({ label:x.label, run:()=>this.runQuery(x.ds,x.q) }));
    const recents = s.history.slice(0,3).map(h=>({ q:h.q, meta:h.time, run:()=>this.runQuery(h.ds||this.detectDataset(h.q), h.q) }));

    // parsing
    const nFilters = ds.filters.length;
    const visibleFilters = ds.filters.slice(0, Math.min(s.parseStep, nFilters));
    const filtersDone = s.parseStep >= nFilters;
    const pingCount = Math.max(0, s.parseStep - nFilters);
    const showPinging = filtersDone && s.parseStep > nFilters;
    const pingRows = actives.map((p,i)=>{
      const done = i < pingCount;
      return { name:p.name, status: done?'answered':'querying…',
        dotStyle:`width:7px;height:7px;border-radius:50%;flex:none;background:${done?'#1a7a4d':'#ef6a2a'};${done?'':'animation:pulse 1.4s infinite'}`,
        statusStyle:`font-size:11.5px;color:${done?'#1a7a4d':'#8a8378'}` };
    });

    // results enriched
    const cheapestOf = (p)=> Math.min(...p.avail.map(a=>a.price));
    const results = ds.parts.map(p => {
      const cheapest = cheapestOf(p);
      const totalStock = p.avail.reduce((a,b)=>a+b.stock,0);
      const inCompare = s.compare.includes(p.id);
      return {
        ...p,
        priceLabel: '$'+cheapest.toFixed(2),
        stockLabel: this.fmt(totalStock)+' in stock',
        availLabel: p.avail.map(a=>a.p).join(', '),
        keySpecs: p.specs.slice(0,4),
        badges: p.badges.map(b=>({ label:b.label, style:`display:inline-flex;align-items:center;gap:5px;font-family:'JetBrains Mono',monospace;font-size:10.5px;padding:3px 9px;border-radius:999px;${b.ok?'background:rgba(78,196,106,.14);color:#1a7a4d':b.warn?'background:rgba(239,106,42,.12);color:#c9521a':'background:rgba(42,78,168,.1);color:#2a4ea8'}` })),
        avail: p.avail.map(a=>({p:a.p})),
        matchBarStyle:`display:block;height:100%;width:${p.match}%;background:#ef6a2a`,
        open: () => this.openDetail(p.id),
        toggleCompare: (e)=>{ if(e&&e.stopPropagation)e.stopPropagation(); this.toggleCompareId(p.id); },
        compareBtnLabel: inCompare?'Added':'Compare',
        compareBtnStyle:`display:inline-flex;align-items:center;gap:6px;border-radius:999px;padding:8px 14px;font-size:13px;cursor:pointer;border:1px solid ${inCompare?'rgba(239,106,42,.5)':'rgba(12,11,9,.12)'};background:${inCompare?'rgba(239,106,42,.1)':'transparent'};color:${inCompare?'#c9521a':'#0c0b09'}`,
        compareMiniLabel: inCompare?'✓ Added':'+ Compare',
        compareMiniStyle:`border-radius:999px;padding:6px 12px;font-size:12px;cursor:pointer;border:1px solid ${inCompare?'rgba(239,106,42,.5)':'rgba(12,11,9,.12)'};background:${inCompare?'rgba(239,106,42,.1)':'transparent'};color:${inCompare?'#c9521a':'#0c0b09'};font-family:'JetBrains Mono',monospace`,
        cardStyle:`position:relative;cursor:pointer;border:1px solid ${p.best?'rgba(239,106,42,.35)':'rgba(12,11,9,.08)'};border-radius:18px;background:#f8f5f0;padding:24px 26px;transition:all .15s;${p.best?'box-shadow:0 20px 50px -30px rgba(239,106,42,.4)':''}`,
        gridCardStyle:`cursor:pointer;border:1px solid rgba(12,11,9,.08);border-radius:16px;background:#f8f5f0;padding:20px;transition:all .15s`,
      };
    });
    const filters = ds.filters.map((f,i)=>({ k:f.k, v:f.v, remove:()=>this.removeFilter(i) }));

    // compare tray
    const trayParts = s.compare.map(id=>{ const p=this.partById(id); return { mpn:p.mpn, remove:(e)=>{ if(e&&e.stopPropagation)e.stopPropagation(); this.toggleCompareId(id); } }; });

    // saved
    const savedList = s.saved.map(id=>{ const p=this.partById(id)||this.findAnywhere(id); return p?{ mpn:p.mpn, mfr:p.mfr, shortDesc:p.shortDesc, priceLabel:'$'+cheapestOf(p).toFixed(2), open:()=>this.openDetail(p.id) }:null; }).filter(Boolean);

    // history
    const historyList = s.history.map(h=>({ ...h, run:()=>this.runQuery(h.ds||this.detectDataset(h.q), h.q) }));

    // assistant
    const chat = s.chat.map(m=>({ text:m.text,
      rowStyle:`display:flex;${m.role==='user'?'justify-content:flex-end':'justify-content:flex-start'}`,
      bubbleStyle:`max-width:86%;font-size:13.5px;line-height:1.55;padding:12px 16px;${m.role==='user'?'background:#ef6a2a;color:#fff;border-radius:14px 14px 4px 14px':'background:rgba(255,255,255,.06);color:#f4efe8;border-radius:14px 14px 14px 4px'}`,
    }));
    const presetQuestions = (this.ASSISTANT[s.ds]||[]).map(q=>({ q:q.q, send:()=>this.sendPreset(q) }));

    const seg = (on)=>`display:flex;align-items:center;justify-content:center;width:30px;height:26px;border:none;border-radius:7px;cursor:pointer;background:${on?'#f8f5f0':'transparent'};color:${on?'#0c0b09':'#8a8378'};box-shadow:${on?'0 1px 3px rgba(0,0,0,.08)':'none'}`;

    // ---- detail ----
    const part = this.partById(s.selected) || {};
    const isPartSaved = s.saved.includes(s.selected);
    const detailInCompare = s.compare.includes(s.selected);
    const detailTabsDef = [['overview','Overview'],['pricing','Pricing'],['datasheet','Datasheet'],['downloads','CAD & downloads'],['pinout','Pinout'],['3d','3D model'],['alt','Alternatives']];
    const detailTabs = detailTabsDef.map(([id,label])=>({ id,label, onClick:()=>this.setTab(id),
      style:`background:none;border:none;cursor:pointer;font-size:13.5px;padding:12px 2px;white-space:nowrap;color:${s.detailTab===id?'#0c0b09':'#8a8378'};font-weight:${s.detailTab===id?'500':'400'};border-bottom:2px solid ${s.detailTab===id?'#ef6a2a':'transparent'};margin-bottom:-1px` }));
    const dCheapest = part.avail ? Math.min(...part.avail.map(a=>a.price)) : 0;
    const dStock = part.avail ? part.avail.reduce((a,b)=>a+b.stock,0):0;
    const pkgSpec = (part.specs||[]).find(x=>x.k==='Package');
    const partSpecs = part.specs||[];
    const distributors = (part.avail||[]).map(a=>({
      p:a.p, stockLabel:this.fmt(a.stock)+' in stock', best:a.price===dCheapest, priceLabel:'$'+a.price.toFixed(2),
      headStyle:`display:flex;align-items:center;justify-content:space-between;margin-bottom:14px`,
      cardStyle:`border:1px solid ${a.price===dCheapest?'rgba(239,106,42,.35)':'rgba(12,11,9,.08)'};border-radius:14px;background:#f8f5f0;padding:18px 20px`,
      tiers:[{q:'1',f:1},{q:'10',f:0.9},{q:'100',f:0.78},{q:'1,000',f:0.66}].map(t=>({q:t.q,price:'$'+(a.price*t.f).toFixed(a.price*t.f<1?3:2)})),
    }));
    const cad = part.cad||{};
    const downloads = [
      {type:'Schematic symbol', avail:!!cad.symbol, src:cad.src},
      {type:'PCB footprint', avail:!!cad.footprint, src:cad.src},
      {type:'3D STEP model', avail:!!cad.step, src:cad.src},
      {type:'Datasheet (PDF)', avail:true, src:part.mfr},
    ].map(d=>({ type:d.type,
      rowStyle:`display:flex;align-items:center;gap:14px;padding:15px 18px;border:1px solid rgba(12,11,9,.08);border-radius:12px;background:${d.avail?'#f8f5f0':'rgba(12,11,9,.02)'}`,
      iconStyle:`width:34px;height:34px;flex:none;border-radius:9px;display:flex;align-items:center;justify-content:center;background:${d.avail?'rgba(239,106,42,.1)':'rgba(12,11,9,.05)'};color:${d.avail?'#ef6a2a':'#8a8378'}`,
      statusStyle:`font-family:'JetBrains Mono',monospace;font-size:11px;color:${d.avail?'#1a7a4d':'#8a8378'}`,
      status:d.avail?('available · '+d.src):'not available from selected providers',
      avail:d.avail,
      btnLabel:d.avail?'Download':'Unavailable',
      btnStyle:`display:inline-flex;align-items:center;gap:7px;border-radius:999px;padding:8px 15px;font-size:12.5px;cursor:${d.avail?'pointer':'not-allowed'};border:1px solid ${d.avail?'rgba(12,11,9,.14)':'transparent'};background:${d.avail?'transparent':'rgba(12,11,9,.04)'};color:${d.avail?'#0c0b09':'#8a8378'};font-family:'JetBrains Mono',monospace` }));
    const pins = part.pins||[];
    const hasPins = pins.length>0;
    const pinRows = pins.map(p=>({ n:p.n, name:p.name, type:{P:'Power',I:'Input',O:'Output',IO:'Bidir'}[p.t]||p.t,
      typeStyle:`font-family:'JetBrains Mono',monospace;font-size:10.5px;padding:2px 8px;border-radius:5px;${p.t==='P'?'background:rgba(239,106,42,.12);color:#c9521a':p.t==='O'?'background:rgba(78,196,106,.14);color:#1a7a4d':'background:rgba(42,78,168,.1);color:#2a4ea8'}` }));
    const alternatives = (ds.parts||[]).filter(p=>p.id!==s.selected).map(p=>({ mpn:p.mpn, mfr:p.mfr, match:p.match, priceLabel:'$'+Math.min(...p.avail.map(a=>a.price)).toFixed(2), shortDesc:p.shortDesc, open:()=>this.openDetail(p.id) }));
    const importTargets = ['KiCad','Altium Designer','EasyEDA','Fusion 360'].map(t=>({ label:t, pick:()=>this.pickImport(t, part.mpn) }));

    // ---- compare ----
    const cmpParts = s.compare.map(id=>this.partById(id)).filter(Boolean);
    const cmpN = cmpParts.length;
    const cmpGrid = `minmax(150px,1.1fr) repeat(${Math.max(cmpN,1)},1fr)`;
    let cmpRows=[], cmpSummary='', cmpHead=[];
    cmpHead = cmpParts.map(p=>({ mpn:p.mpn, mfr:p.mfr, priceLabel:'$'+Math.min(...p.avail.map(a=>a.price)).toFixed(2), open:()=>this.openDetail(p.id), remove:()=>this.toggleCompareId(p.id) }));
    if(cmpN){
      const keys=[]; cmpParts.forEach(p=>p.specs.forEach(sp=>{ if(!keys.includes(sp.k)) keys.push(sp.k); }));
      const raw=[
        { label:'Best price', cells:cmpParts.map(p=>({ v:'$'+Math.min(...p.avail.map(a=>a.price)).toFixed(2), accent:true })) },
        { label:'Match', cells:cmpParts.map(p=>({ v:p.match+'%' })) },
        { label:'Available at', cells:cmpParts.map(p=>({ v:p.avail.map(a=>a.p).join(', '), small:true })) },
        ...keys.map(k=>({ label:k, cells:cmpParts.map(p=>{ const f=p.specs.find(x=>x.k===k); return {v:f?f.v:'—'}; }) })),
      ];
      cmpRows=raw.map((r,ri)=>({ label:r.label, rowStyle:`display:grid;grid-template-columns:${cmpGrid};gap:12px;padding:11px 18px;border-bottom:1px solid rgba(12,11,9,.06);${ri%2?'background:rgba(12,11,9,.015)':''}`,
        cells:r.cells.map(c=>({ v:c.v, style:`font-family:'JetBrains Mono',monospace;${c.small?"font-size:11px;color:#8a8378":c.accent?'font-size:14px;color:#c9521a;font-weight:500':'font-size:13px;color:#0c0b09'}` })) }));
      const cheap=cmpParts.reduce((a,b)=>Math.min(...b.avail.map(x=>x.price))<Math.min(...a.avail.map(x=>x.price))?b:a);
      const best=cmpParts.reduce((a,b)=>b.match>a.match?b:a);
      const nuance={reg:'For a 24 V→5 V rail at 3 A, favour the synchronous parts for efficiency and cooler operation.',esp:'If you need native USB OTG, choose an S3-family module; for the lowest power draw the C6 leads.',opamp:'On a single 5 V supply, prioritise parts rated for single-supply operation over the ±-supply noise specialists.'}[s.ds]||'';
      cmpSummary=`${best.mpn} is the closest match to your query at ${best.match}%. ${cheap.mpn===best.mpn?'It is also the lowest-cost option in this set':cheap.mpn+' is the lowest-cost option at $'+Math.min(...cheap.avail.map(x=>x.price)).toFixed(2)}. ${nuance}`;
    }

    return {
      // nav + view flags
      isHome: view==='home', isParsing: view==='parsing', isResults: view==='results',
      isDetail: view==='detail', isCompare: view==='compare', isSaved: view==='saved',
      isHistory: view==='history', isProviders: view==='providers',
      navSearchStyle: this.navItem(inSearch), navSavedStyle: this.navItem(view==='saved'),
      navHistoryStyle: this.navItem(view==='history'), navProvidersStyle: this.navItem(view==='providers'),
      navCompareStyle: this.navItem(view==='compare'),
      goHome:this.goHome, goSaved:this.goSaved, goHistory:this.goHistory, goProviders:this.goProviders, goSearch:this.goSearch, goCompare:this.goCompare,
      crumb, providerCount, savedCount: s.saved.length,
      hasCompare: s.compare.length>0, compareCount: s.compare.length,

      // home
      draftQuery: s.draftQuery, onQueryChange:this.onQueryChange, onQueryKey:this.onQueryKey, submitSearch:this.submitSearch,
      suggestions, recents, providersList, showCaps:s.showCaps, toggleCapView:this.toggleCapView,
      capViewLabel: s.showCaps?'Hide capabilities':'Show capabilities',

      // parsing
      query: s.query, visibleFilters, filtersDone, showPinging, pingRows,

      // results
      resultCount: results.length, results, filters,
      layout:s.layout, layoutCards:s.layout==='cards', layoutRows:s.layout==='rows', layoutGrid:s.layout==='grid',
      setLayoutCards:()=>this.setLayout('cards'), setLayoutRows:()=>this.setLayout('rows'), setLayoutGrid:()=>this.setLayout('grid'),
      segCardsStyle:seg(s.layout==='cards'), segRowsStyle:seg(s.layout==='rows'), segGridStyle:seg(s.layout==='grid'),

      // tray
      showTray: s.compare.length>0 && view!=='compare', trayParts, openCompare:this.openCompare,
      compareGoStyle:`display:inline-flex;align-items:center;gap:8px;background:${s.compare.length>=2?'#ef6a2a':'rgba(255,255,255,.1)'};color:#fff;border:none;border-radius:12px;padding:10px 18px;font-size:13.5px;font-weight:500;cursor:${s.compare.length>=2?'pointer':'not-allowed'};font-family:'Inter',sans-serif`,

      // saved / history
      hasSaved: s.saved.length>0, savedList, historyList,

      // assistant
      assistantOpen: s.assistantOpen, toggleAssistant:this.toggleAssistant, chat, presetQuestions, assistantTyping:s.typing,
      assistantContext: s.query ? ('Context · '+s.query.replace(/\.$/,'')) : 'Suggested questions',
      assistantWrapStyle:`position:absolute;top:0;right:0;bottom:0;width:400px;max-width:92vw;background:#0c0b09;border-left:1px solid rgba(255,255,255,.08);z-index:30;display:flex;flex-direction:column;transform:translateX(${s.assistantOpen?'0':'100%'});transition:transform .3s ease;box-shadow:-30px 0 80px -20px rgba(0,0,0,.5)`,

      // detail
      backToResults:this.backToResults, detailTabs,
      tabOverview:s.detailTab==='overview', tabPricing:s.detailTab==='pricing', tabDatasheet:s.detailTab==='datasheet',
      tabDownloads:s.detailTab==='downloads', tabPinout:s.detailTab==='pinout', tab3d:s.detailTab==='3d', tabAlt:s.detailTab==='alt',
      partMpn:part.mpn, partMfr:part.mfr, partDesc:part.desc, partPriceLabel:'$'+dCheapest.toFixed(2),
      partStockLabel:this.fmt(dStock)+' in stock', partPkg:pkgSpec?pkgSpec.v:'—', partSpecs,
      distributors, downloads, hasPins, pinRows, alternatives, cad3dSrc:cad.src||'—', cadHasStep:!!cad.step,
      isPartSaved, saveLabel:isPartSaved?'Saved':'Save', toggleSaveSel:()=>this.toggleSave(s.selected),
      detailInCompare, detailCompareLabel:detailInCompare?'In compare':'Compare', toggleCompareSel:()=>this.toggleCompareId(s.selected),
      importOpen:s.importOpen, toggleImport:this.toggleImport, importTargets,
      saveBtnStyle:`display:inline-flex;align-items:center;gap:7px;border-radius:999px;padding:10px 16px;font-size:13.5px;cursor:pointer;border:1px solid ${isPartSaved?'rgba(239,106,42,.5)':'rgba(12,11,9,.14)'};background:${isPartSaved?'rgba(239,106,42,.1)':'transparent'};color:${isPartSaved?'#c9521a':'#0c0b09'}`,
      cmpBtnStyle:`display:inline-flex;align-items:center;gap:7px;border-radius:999px;padding:10px 16px;font-size:13.5px;cursor:pointer;border:1px solid ${detailInCompare?'rgba(239,106,42,.5)':'rgba(12,11,9,.14)'};background:${detailInCompare?'rgba(239,106,42,.1)':'transparent'};color:${detailInCompare?'#c9521a':'#0c0b09'}`,

      // compare
      cmpParts, cmpN, cmpHasEnough:cmpN>=2, cmpHead, cmpRows, cmpSummary,
      cmpGridStyle:`display:grid;grid-template-columns:${cmpGrid};gap:12px`,
      clearCompare:this.clearCompare,

      // toast
      toast:s.toast, hasToast:!!s.toast,
    };
  }

  findAnywhere(id){ for(const k in this.DATASETS){ const p=this.DATASETS[k].parts.find(x=>x.id===id); if(p) return p; } return null; }
}
</script>
</body>
</html>
